# Acuity Scheduling API Credentials
# Copy this file to .env.test.local and fill in your credentials
# DO NOT commit .env.test.local to version control

# Acuity User ID (numeric) - found in Business Settings → Integrations → API
ACUITY_USER_ID=

# Acuity API Key - found in Business Settings → Integrations → API
ACUITY_API_KEY=

# Enable live API tests (set to "true" to run)
RUN_LIVE_TESTS=false
